{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "视频字幕学习台",
  "version": "0.1.0",
  "identifier": "com.sykqw.video-subtitle-learning",
  "build": {
    "beforeDevCommand": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-dev.ps1",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "视频字幕学习台",
        "width": 1460,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
